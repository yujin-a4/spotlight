# === 이 파일을 .env.local 로 복사한 뒤 값을 채우세요 ===

# Gemini API 키 (서버 전용 — 절대 NEXT_PUBLIC_ 붙이지 말 것)
# 발급: https://ai.studio → Get API key (해커톤 @gcplab.me 계정)
GEMINI_API_KEY=

# Google Maps JavaScript API 키
# 발급: GCP 콘솔 → API 및 서비스 → 사용자 인증 정보 → API 키 만들기
# (Maps JavaScript API 사용 설정 필요)
NEXT_PUBLIC_MAPS_API_KEY=

# Firebase 웹 앱 설정
# 발급: Firebase 콘솔 → 프로젝트 설정 → 내 앱 → 웹 앱 추가 → SDK 설정값 복사
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
